{
  "name": "@fbsm/saga-monorepo",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "pnpm -r --filter './packages/**' run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -b",
    "clean": "pnpm -r exec rm -rf dist tsconfig.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@vitest/coverage-v8": "^3.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.0"
  }
}