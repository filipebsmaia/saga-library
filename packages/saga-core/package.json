{
  "name": "@fbsm/saga-core",
  "version": "0.1.0-beta.1",
  "description": "Framework-agnostic saga choreography core: runner, publisher, parser, context management",
  "license": "MIT",
  "author": "fbsm",
  "repository": {
    "type": "git",
    "url": "https://github.com/fbsm/saga-library",
    "directory": "packages/saga-core"
  },
  "keywords": [
    "saga",
    "choreography",
    "microservices",
    "event-driven",
    "distributed-transactions"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "uuid": "^11.0.0"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  }
}
