{
  "name": "@fbsm/saga-nestjs",
  "version": "0.1.0-beta.1",
  "description": "NestJS integration for saga choreography: dynamic module, decorators, auto-discovery",
  "license": "MIT",
  "author": "fbsm",
  "repository": {
    "type": "git",
    "url": "https://github.com/fbsm/saga-library",
    "directory": "packages/saga-nestjs"
  },
  "keywords": [
    "saga",
    "nestjs",
    "choreography",
    "microservices",
    "event-driven"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fbsm/saga-core": "workspace:*"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  }
}
