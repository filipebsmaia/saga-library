{
  "name": "@fbsm/saga-transport-kafka",
  "version": "0.1.0-beta.3",
  "description": "KafkaJS transport adapter for saga choreography: eachBatch, watermark offset tracking",
  "license": "MIT",
  "author": "fbsm",
  "repository": {
    "type": "git",
    "url": "https://github.com/fbsm/saga-library",
    "directory": "packages/saga-transport-kafka"
  },
  "keywords": [
    "saga",
    "kafka",
    "kafkajs",
    "transport",
    "microservices",
    "event-driven"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fbsm/saga-core": "workspace:*",
    "kafkajs": "^2.2.0"
  },
  "peerDependencies": {
    "@opentelemetry/instrumentation-kafkajs": "^0.7.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/instrumentation-kafkajs": {
      "optional": true
    }
  }
}
