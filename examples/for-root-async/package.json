{
  "name": "@fbsm/saga-example-async",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r reflect-metadata src/main.ts",
    "docker:up": "docker compose -f ../order-saga/docker-compose.yml up -d kafka",
    "docker:down": "docker compose -f ../order-saga/docker-compose.yml down"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@fbsm/saga-core": "workspace:*",
    "@fbsm/saga-nestjs": "workspace:*",
    "@fbsm/saga-transport-kafka": "workspace:*",
    "kafkajs": "^2.2.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.0"
  }
